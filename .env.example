# DeepSeek API(用 openai SDK 指向 DeepSeek base_url)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型分工:
#  - 每日任务生成(高频、实时):deepseek-chat(V3,快)
#  - 周度总结/阶段校准(低频、深推理):deepseek-reasoner(R1,慢但思考深)
MODEL_FAST=deepseek-chat
MODEL_DEEP=deepseek-reasoner

# Database(SQLite 相对路径,相对 backend/)
DATABASE_URL=sqlite:///./cco.db

# API server
API_HOST=127.0.0.1
API_PORT=8000

# 前端地址(CORS 白名单用)
FRONTEND_ORIGIN=http://localhost:3000

# 开发模式:true = mock LLM 响应,不花 token;false = 真实调用
MOCK_LLM=false
